XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4.3
XAI_API_BASE=https://api.x.ai/v1
HOST=127.0.0.1
PORT=4173

# Production hardening
NODE_ENV=development
TRUTH_WORLD_AUTH_STORE=data/auth-store.dev.json
TRUTH_WORLD_AI_QUOTA_MAX=30
TRUTH_WORLD_AI_QUOTA_WINDOW_MS=60000
TRUTH_WORLD_FEED_QUOTA_MAX=120
TRUTH_WORLD_FEED_QUOTA_WINDOW_MS=60000
TRUTH_WORLD_AUTH_QUOTA_MAX=20
TRUTH_WORLD_AUTH_QUOTA_WINDOW_MS=300000
# Only enable forwarded headers behind a trusted reverse proxy.
# TRUTH_WORLD_TRUST_PROXY_HEADERS=1
# TRUTH_WORLD_TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.7

# Codex fallback is local-host only and disabled automatically when NODE_ENV=production.
# TRUTH_WORLD_ALLOW_CODEX_TRANSLATION_IN_PRODUCTION=1
# TRUTH_WORLD_ALLOW_REMOTE_CODEX_TRANSLATION=1

# Phone/country verification. Use dev_auto only for local development.
TRUTH_WORLD_PHONE_VERIFICATION_MODE=dev_auto
# TRUTH_WORLD_PHONE_VERIFICATION_MODE=twilio
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
# TRUTH_WORLD_PHONE_VERIFICATION_MODE=external
# TRUTH_WORLD_PHONE_VERIFY_START_URL=https://verify.example/start
# TRUTH_WORLD_PHONE_VERIFY_CHECK_URL=https://verify.example/check
# TRUTH_WORLD_PHONE_VERIFY_API_KEY=your_verify_api_key

# Optional host allowlists. Source hosts default to Truth Social only.
# If media hosts are not configured, remote images fall back to local artwork.
# Production rejects http: URLs and wildcard allowlists.
# TRUTH_WORLD_ALLOWED_SOURCE_HOSTS=truthsocial.com,truthworld.local
# TRUTH_WORLD_ALLOWED_MEDIA_HOSTS=media.example,cdn.example
